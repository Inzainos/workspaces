# Sentinel Omega — variables de entorno
# Copia este archivo a deploy/.env y llena tus keys.
# NUNCA subas deploy/.env a git (ya está en .gitignore).

# Alertas Telegram (rojo/amarillo al celular)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Datos atmosféricos / desgasificación (OpenWeatherMap)
OPENWEATHERMAP_KEY=

# Asteroides NEO (gratis en https://api.nasa.gov — DEMO_KEY funciona limitado)
NASA_API_KEY=DEMO_KEY

# Satélites Copernicus (descarga de productos; búsqueda funciona sin esto)
COPERNICUS_USER=
COPERNICUS_PASSWORD=

# Financieros (opcionales — Yahoo funciona sin key)
COINGECKO_API_KEY=
ALPHA_VANTAGE_KEY=
BITSO_API_KEY=
BITSO_API_SECRET=
