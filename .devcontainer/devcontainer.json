{
  "name": "Sentinel Omega",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "postStartCommand": "bash .devcontainer/postStart.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.pylance"
      ]
    }
  },
  "forwardPorts": [8501],
  "portsAttributes": {
    "8501": {
      "label": "Dashboard Streamlit",
      "onAutoForward": "notify"
    }
  }
}
