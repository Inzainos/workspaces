{
  "name": "Sentinel Omega — Jupyter + Streamlit",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",

  // Instala dependencias y prepara carpetas al crear el contenedor
  "postCreateCommand": "bash .devcontainer/postCreate.sh",

  // Puertos disponibles automáticamente en Codespaces
  // 8888 = JupyterLab  |  8501 = Streamlit dashboard
  "forwardPorts": [8888, 8501],
  "portsAttributes": {
    "8888": {
      "label": "JupyterLab",
      "onAutoForward": "notify"
    },
    "8501": {
      "label": "Streamlit Dashboard",
      "onAutoForward": "notify"
    }
  },

  // Extensiones de VS Code que se instalan automáticamente
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter",
        "ms-toolsai.jupyter-renderers",
        "ms-toolsai.vscode-jupyter-cell-tags"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "jupyter.notebookFileRoot": "${workspaceFolder}"
      }
    }
  },

  // Variables de entorno para el modo Jupyter (sin Telegram, sin side-effects)
  "remoteEnv": {
    "JUPYTER_ENABLED": "true",
    "JUPYTER_DISABLE_TELEGRAM": "true"
  }
}
